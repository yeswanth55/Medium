generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String
  post     Posts[]
}

model Posts {
  id          String  @id @default(uuid())
  title       String
  description String
  check       Boolean @default(false)
  authorId    String
  author      User    @relation(fields: [authorId], references: [id])
}
